<?xml version="1.0"?>
<Container version="2">
  <Name>Lavalink for Discord Music Bot</Name>
  <Repository>ghcr.io/lavalink-devs/lavalink:4-alpine</Repository>
  <Registry>https://github.com/lavalink-devs/Lavalink/pkgs/container/lavalink</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://forums.unraid.net/</Support>
  <Project>https://github.com/lavalink-devs/Lavalink</Project>
  <Overview>Lavalink v4 audio node for the Discord Music Bot. Use this together with the Discord Music Bot template.</Overview>
  <Category>Network:Other MediaApp:Music</Category>
  <WebUI/>
  <TemplateURL/>
  <Icon>https://raw.githubusercontent.com/simple-icons/simple-icons/develop/icons/docker.svg</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled>0</DateInstalled>
  <DonateText/>
  <DonateLink/>
  <Description>Lavalink backend with the official YouTube plugin enabled. Keep the container name as lavalink unless you also change LAVALINK_HOST in the bot template.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish/>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/discord-music-bot/lavalink/application.yml</HostDir>
      <ContainerDir>/opt/Lavalink/application.yml</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
    <Volume>
      <HostDir>/mnt/user/appdata/discord-music-bot/lavalink/plugins</HostDir>
      <ContainerDir>/opt/Lavalink/plugins</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment/>
  <Labels/>
  <Config Name="Application Yaml" Target="/opt/Lavalink/application.yml" Default="/mnt/user/appdata/discord-music-bot/lavalink/application.yml" Mode="rw" Description="Path to the Lavalink application.yml file." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/discord-music-bot/lavalink/application.yml</Config>
  <Config Name="Plugins Folder" Target="/opt/Lavalink/plugins" Default="/mnt/user/appdata/discord-music-bot/lavalink/plugins" Mode="rw" Description="Persistent folder for downloaded Lavalink plugins." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/discord-music-bot/lavalink/plugins</Config>
</Container>
